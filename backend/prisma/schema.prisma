datasource db{
    provider = "postgresql"
    url = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}


//Todo: User model optimization
model User{
    id  Int @id @default(autoincrement())
    username String @unique
    email String @unique
    password String
    profilePic String?
    bio String?
    followerCount Int @default(0) //Todo: Takipçi sayısı
    followingCount Int @default(0) //Todo: Takip edilen sayısı
    createdAt DateTime @default(now())

    posts Post[]
    likes Like[]
    comments Comment[]
    followers Follow[] @relation("UserFollowers") //Todo: Takipçi ilişkisi
    following Follow[] @relation("UserFollowing") //Todo: Takip edilen ilişkisi

    @@index([username])  //Todo: Optimize username lookups
}


//Todo: Post model optimization
model Post{
    id Int @id @default(autoincrement())
    caption String?
    imageUrl String
    likesCount Int @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId Int
    user User @relation(fields: [userId], references: [id])
    likes Like[]
    comments Comment[]

    @@index([userId]) //Todo: Bir kullanıcının tüm postları
    @@index([createdAt]) //Todo: Zamana göre sıralama
}


//Todo: Like model optimization
model Like{
    id Int @id @default(autoincrement())
    createdAt DateTime @default(now())

    //Todo: İlişkiler
    userId Int
    user User @relation(fields: [userId], references: [id])

    postId Int
    post Post @relation(fields: [postId], references: [id])

    @@unique([userId,postId]) //Todo: Aynı kullanıcının aynı postu birden fazla beğenmesini engeller
    @@index([postId]) //Todo: Bir postun tüm like'ları
    @@index([userId]) //Todo: Bir kullanıcının beğendiği postlar
}

model Comment{
    id Int @id @default(autoincrement())
    content String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    //Todo: İlişkiler
    userId Int
    user User @relation(fields: [userId],references: [id])


    postId Int
    post Post @relation(fields: [postId], references: [id])


    //Todo: Optimize Edilmiş Sorgular için indexler
    @@index([postId])
    @@index([userId])
    @@index([createdAt])
}


//Todo:Takip - Sistemi
model Follow{
    id Int @id @default(autoincrement())
    createdAt DateTime @default(now())

    //Todo:Takip eden kullanıcı
    followerId Int
    follower User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)

    //Todo: Takip edilen kullanıcı 
    followingId Int
    following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

    @@unique([followerId,followingId]) //Todo: Aynı kullanıcının aynı kişiyi birden fazla takip etmesini engeller
    @@index([followerId]) //Todo: Bir kullanıcının takip ettiği kişiler
    @@index([followingId]) //Todo: Bir kullanıcının takipçileri
}