datasource db{
    provider = "postgresql"
    url = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}


//Todo: User model optimization
model User{
    id  Int @id @default(autoincrement())
    username String @unique
    email String @unique
    password String
    profilePic String?
    bio String?
    createdAt DateTime @default(now())

    posts Post[]
    likes Like[]
    comments Comment[]

    @@index([username])  //Todo: Optimize username lookups
}


//Todo: Post model optimization
model Post{
    id Int @id @default(autoincrement())
    caption String?
    imageUrl String
    likesCount Int @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId Int
    user User @relation(fields: [userId], references: [id])
    likes Like[]
    comments Comment[]

    @@index([userId]) //Todo: Bir kullanıcının tüm postları
    @@index([createdAt]) //Todo: Zamana göre sıralama
}


//Todo: Like model optimization
model Like{
    id Int @id @default(autoincrement())
    createdAt DateTime @default(now())

    //Todo: İlişkiler
    userId Int
    user User @relation(fields: [userId], references: [id])

    postId Int
    post Post @relation(fields: [postId], references: [id])

    @@unique([userId,postId]) //Todo: Aynı kullanıcının aynı postu birden fazla beğenmesini engeller
    @@index([postId]) //Todo: Bir postun tüm like'ları
    @@index([userId]) //Todo: Bir kullanıcının beğendiği postlar
}

model Comment{
    id Int @id @default(autoincrement())
    content String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    //Todo: İlişkiler
    userId Int
    user User @relation(fields: [userId],references: [id])


    postId Int
    post Post @relation(fields: [postId], references: [id])


    //Todo: Optimize Edilmiş Sorgular için indexler
    @@index([postId])
    @@index([userId])
    @@index([createdAt])
}